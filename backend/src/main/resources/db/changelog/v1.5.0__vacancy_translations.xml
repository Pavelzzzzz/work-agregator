<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="v1.5.0-create-vacancy-translations" author="vacancyscout">
        <createTable tableName="vacancy_translations">
            <column name="vacancy_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_vacancy_translations_vacancy"
                             references="vacancies(id)"/>
            </column>
            <column name="lang" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(500)"/>
            <column name="company_name" type="varchar(255)"/>
            <column name="description" type="text"/>
            <column name="requirements" type="text"/>
            <column name="responsibilities" type="text"/>
            <column name="search_vector" type="tsvector"/>
        </createTable>
        <addPrimaryKey tableName="vacancy_translations"
                       columnNames="vacancy_id,lang"
                       constraintName="pk_vacancy_translations"/>
        <sql>CREATE INDEX IF NOT EXISTS idx_vt_search_vector ON vacancy_translations USING GIN (search_vector)</sql>
    </changeSet>

    <changeSet id="v1.5.0-drop-vacancy-translate-columns" author="vacancyscout">
        <dropColumn tableName="vacancies">
            <column name="search_vector_ru"/>
            <column name="search_vector_en"/>
            <column name="description_en"/>
            <column name="requirements_en"/>
            <column name="responsibilities_en"/>
            <column name="title_translated"/>
            <column name="company_name_translated"/>
        </dropColumn>
    </changeSet>
</databaseChangeLog>
