<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="v1.1.0-vacancy-indexes" author="vacancyscout">
        <createIndex tableName="vacancies" indexName="idx_vacancies_source">
            <column name="source_name"/>
        </createIndex>
        <createIndex tableName="vacancies" indexName="idx_vacancies_company">
            <column name="company_name"/>
        </createIndex>
        <createIndex tableName="applications" indexName="idx_applications_vacancy">
            <column name="vacancy_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
